local player = game:GetService("Players").LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

_G.AutoFarm = _G.AutoFarm or false
_G.WalkSpeedValue = _G.WalkSpeedValue or 80

-- Xóa UI cũ nếu đã tồn tại
if playerGui:FindFirstChild("SuFarmerControlUI") then
    playerGui.SuFarmerControlUI:Destroy()
end

local screenGui = Instance.new("ScreenGui", playerGui)
screenGui.Name = "SuFarmerControlUI"
screenGui.ResetOnSpawn = false

local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 110, 0, 50)
frame.Position = UDim2.new(0, 10, 0, 150) -- Chỉnh lại vị trí để không bị che
frame.BackgroundTransparency = 0.5
frame.BackgroundColor3 = Color3.new(0, 0, 0)

local farmBtn = Instance.new("TextButton", frame)
farmBtn.Size = UDim2.new(0, 50, 0, 50)
farmBtn.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
farmBtn.TextScaled = true
local stroke1 = Instance.new("UIStroke", farmBtn)
stroke1.Color = Color3.new(1, 1, 1)

local speedBtn = Instance.new("TextButton", frame)
speedBtn.Size = UDim2.new(0, 50, 0, 50)
speedBtn.Position = UDim2.new(0, 55, 0, 0)
speedBtn.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
speedBtn.TextScaled = true
local stroke2 = Instance.new("UIStroke", speedBtn)
stroke2.Color = Color3.new(1, 1, 1)

local function updateUI()
    farmBtn.Text = _G.AutoFarm and "FARM\nBẬT" or "FARM\nTẮT"
    farmBtn.TextColor3 = _G.AutoFarm and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    speedBtn.Text = "SPEED\n" .. tostring(_G.WalkSpeedValue)
    speedBtn.TextColor3 = Color3.new(1, 1, 1)
end

farmBtn.MouseButton1Click:Connect(function()
    _G.AutoFarm = not _G.AutoFarm
    updateUI()
end)

speedBtn.MouseButton1Click:Connect(function()
    if _G.WalkSpeedValue == 80 then
        _G.WalkSpeedValue = 200
    elseif _G.WalkSpeedValue == 200 then
        _G.WalkSpeedValue = 355
    else
        _G.WalkSpeedValue = 80
    end
    player.Character.Humanoid.WalkSpeed = _G.WalkSpeedValue
    updateUI()
end)

-- Vòng lặp cập nhật WalkSpeed liên tục để tránh bị game reset
task.spawn(function()
    while true do
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = _G.WalkSpeedValue
        end
        task.wait(0.1)
    end
end)

updateUI()
